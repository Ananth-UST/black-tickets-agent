USER_PASSWORD=replace-with-secure-user-password

AWS_REGION=us-east-1
EVENT_SERVICE_URL=http://event-service:4002
BOOKING_SERVICE_URL=http://booking-service:4003
BOOKING_NOTIFICATION_QUEUE_URL=
