# Production environment variables
# NEVER commit actual secrets to version control
# Use setup-dynamic-env.sh to generate secure values
# For local development, set these environment variables:
# POSTGRES_PASSWORD, JWT_SECRET, ADMIN_PASSWORD, USER_PASSWORD, DB_PASS

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SecureProdPass123!@#
POSTGRES_DB=ticketing_prod

# Service Configuration
COMPOSE_PROJECT_NAME=ticketing-prod
COMPOSE_FILE=docker-compose.yml

# JWT Configuration
JWT_SECRET=SecureJWTSecretKeyForProductionUse64CharsLongRandomString

# Admin/User Configuration
ADMIN_EMAIL=admin@bookish.com
ADMIN_PASSWORD=SecureAdminPass123!@#
USER_EMAIL=user@bookish.com
USER_PASSWORD=SecureUserPass123!@#

# Service Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=SecureProdPass123!@#

# Service Specific Databases
IDENTITY_DB_NAME=identity_db
EVENT_DB_NAME=event_db
BOOKING_DB_NAME=booking_db

# Service URLs
EVENT_SERVICE_URL=http://event-service:4002

# Security Settings
NODE_ENV=production
BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=2h

# Frontend Configuration
VITE_API_BASE_URL=http://3.88.155.191

# Local Development Configuration
# VITE_API_BASE_URL=http://localhost
