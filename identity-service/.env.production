# Production environment for EC2 deployment
# Generate secure values using: node scripts/generate-secrets.js
# NEVER commit actual secrets to version control

PORT=4001
DB_HOST=postgres
DB_PORT=5432
DB_USER=${POSTGRES_USER:-ticketing_user}
DB_PASS=${POSTGRES_PASSWORD:-CHANGE_THIS_STRONG_PASSWORD}
DB_NAME=identity_db
JWT_SECRET=${JWT_SECRET:-CHANGE_THIS_TO_64_CHAR_RANDOM_STRING}
ADMIN_EMAIL=${ADMIN_EMAIL:-admin@yourdomain.com}
ADMIN_PASSWORD=${ADMIN_PASSWORD:-CHANGE_THIS_STRONG_ADMIN_PASSWORD}
USER_EMAIL=${USER_EMAIL:-user@yourdomain.com}
USER_PASSWORD=${USER_PASSWORD:-CHANGE_THIS_STRONG_USER_PASSWORD}

# Security settings
NODE_ENV=production
BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=2h
