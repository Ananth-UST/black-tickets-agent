# Production environment for EC2 deployment
# Generate secure values using: node scripts/generate-secrets.js
# NEVER commit actual secrets to version control

PORT=4003
DB_HOST=postgres
DB_PORT=5432
DB_USER=${POSTGRES_USER:-ticketing_user}
DB_PASS=${POSTGRES_PASSWORD:-CHANGE_THIS_STRONG_PASSWORD}
DB_NAME=booking_db
JWT_SECRET=${JWT_SECRET:-CHANGE_THIS_TO_64_CHAR_RANDOM_STRING}
EVENT_SERVICE_URL=http://event-service:4002

# Security settings
NODE_ENV=production
