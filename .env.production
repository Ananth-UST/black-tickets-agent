# Production environment variables
# NEVER commit actual secrets to version control
# Use setup-dynamic-env.sh to generate secure values
# For local development, set these environment variables:
# POSTGRES_PASSWORD, JWT_SECRET, ADMIN_PASSWORD, USER_PASSWORD, DB_PASS

# Database Configuration
POSTGRES_USER=${POSTGRES_USER:-postgres}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-CHANGE_THIS_STRONG_PASSWORD}
POSTGRES_DB=${POSTGRES_DB:-ticketing_prod}

# Service Configuration
COMPOSE_PROJECT_NAME=ticketing-prod
COMPOSE_FILE=docker-compose.yml

# JWT Configuration
JWT_SECRET=${JWT_SECRET:-CHANGE_THIS_TO_64_CHAR_RANDOM_STRING}

# Admin/User Configuration
ADMIN_EMAIL=${ADMIN_EMAIL:-admin@yourdomain.com}
ADMIN_PASSWORD=${ADMIN_PASSWORD:-CHANGE_THIS_STRONG_ADMIN_PASSWORD}
USER_EMAIL=${USER_EMAIL:-user@yourdomain.com}
USER_PASSWORD=${USER_PASSWORD:-CHANGE_THIS_STRONG_USER_PASSWORD}

# Service Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=${DB_USER:-postgres}
DB_PASS=${DB_PASS:-CHANGE_THIS_STRONG_PASSWORD}

# Service Specific Databases
IDENTITY_DB_NAME=identity_db
EVENT_DB_NAME=event_db
BOOKING_DB_NAME=booking_db

# Service URLs
EVENT_SERVICE_URL=http://event-service:4002

# Security Settings
NODE_ENV=production
BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=2h

# Frontend Configuration
VITE_API_BASE_URL=http://localhost
